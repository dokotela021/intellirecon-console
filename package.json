{
  "name": "intellirecon",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "IntelliRecon — browser-native AI recon console. In-browser terminal + Claude agent driving MCP security tools. Thin backend.",
  "scripts": {
    "dev": "concurrently -k -n web,api,engine,bridge -c cyan,magenta,yellow,blue \"vite\" \"node --env-file-if-exists=.env server/server.mjs\" \"./engine/intellirecon-env/bin/python engine/intellirecon_server.py\" \"./llm-bridge/venv/bin/litellm --config llm-bridge/config.yaml --port 8471\"",
    "build": "vite build",
    "start": "node --env-file-if-exists=.env server/server.mjs",
    "serve": "npm run build && node --env-file-if-exists=.env server/server.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.65.0",
    "@modelcontextprotocol/sdk": "^1.24.1",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "better-sqlite3": "^12.11.1",
    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "lucide-react": "^0.453.0",
    "node-pty": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.12.2",
    "react-router-dom": "^6.27.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.5.4",
    "ws": "^8.18.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "concurrently": "^9.1.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.9"
  }
}
